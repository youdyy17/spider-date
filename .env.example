# Telegram notification secrets used by api/notify.js.
# Copy to `.env` for local `vercel dev`, and set the same keys in the
# Vercel dashboard (Settings → Environment Variables) for production.

# Token from @BotFather (/newbot)
TG_BOT_TOKEN=

# Your chat id. Message your bot once, then open:
#   https://api.telegram.org/bot<TG_BOT_TOKEN>/getUpdates
# and copy result[0].message.chat.id
TG_CHAT_ID=
